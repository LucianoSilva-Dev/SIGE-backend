{
  "name": "sige-backend",
  "version": "1.0.0",
  "description": "Backend API for SIGE platform - NestJS/Prisma",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start --env-file .env",
    "start:dev": "nest start --watch --env-file .env",
    "start:debug": "nest start --debug --watch --env-file .env",
    "start:prod": "node dist/main",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prisma:generate": "prisma generate --schema=src/core/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=src/core/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema=src/core/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/core/prisma/schema.prisma",
    "seed": "tsx --env-file=.env src/core/prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest run --watch"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.0.3",
    "@thallesp/nestjs-better-auth": "^2.1.0",
    "better-auth": "^1.6.11",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "nestjs-zod": "^5.0.1",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "^2.2.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "zod": "^4.1.11"
  },
  "prisma": {
    "schema": "src/core/prisma/schema.prisma",
    "seed": "tsx --env-file=.env src/core/prisma/seed.ts"
  },
  "overrides": {
    "@better-auth/core": "$better-auth"
  }
}
