//- File: temp-password.pug
//- Temporary password email sent after email verification for admin-created students
extends base

block append head
  style.
    .password-box {
      background: #f8f9fa;
      border-radius: 10px;
      padding: 25px;
      margin: 30px 0;
      text-align: center;
      border: 2px solid #CE0E2D;
    }
    
    .password-value {
      font-family: 'Courier New', monospace;
      font-size: 24px;
      font-weight: bold;
      color: #CE0E2D;
      background: #fff;
      padding: 10px 20px;
      border-radius: 6px;
      display: inline-block;
      margin: 10px 0;
      letter-spacing: 2px;
    }
    
    .warning-box {
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 6px;
      padding: 15px;
      margin: 20px 0;
    }

block content
  .content
    p.greeting Olá, #{name}!
    
    p.message Seu e-mail foi verificado com sucesso! Sua conta na Anglo Platform está pronta para uso.
    
    .password-box
      h3(style="color: #CE0E2D; margin-bottom: 20px;") Sua Senha Temporária
      p(style="color: #666; margin-bottom: 15px;") Utilize a senha abaixo para o seu primeiro acesso:
      
      .password-value #{tempPassword}
    
    .warning-box
      p(style="margin: 0; color: #856404;")
        strong ⚠️ Importante: 
        | Recomendamos que você altere sua senha imediatamente após o primeiro acesso.
    
    p.message(style="font-size: 14px; color: #666; margin-top: 20px;")
      | Para acessar, utilize seu e-mail (<strong>#{email}</strong>) e a senha temporária acima.

block footer
  .footer
    p.address
      | Anglo - Plataforma Educacional
    
    p.copyright
      | © #{new Date().getFullYear()} Anglo. Todos os direitos reservados.
