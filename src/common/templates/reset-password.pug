//- File: reset-password.pug
//- Password reset template for better-auth
extends base

block append head
  style.
    .security-box {
      background: #f8f9fa;
      border-radius: 10px;
      padding: 25px;
      margin: 30px 0;
      text-align: center;
      border: 2px solid #CE0E2D;
    }
    
    .security-icon {
      font-size: 48px;
      color: #CE0E2D;
      margin-bottom: 15px;
    }

block content
  .content
    p.greeting Olá, #{name}!
    
    p.message Recebemos uma solicitação para redefinir a senha da sua conta no Anglo. Para continuar com o processo, clique no botão abaixo:
    
    .security-box
      .security-icon 🔒
      h3(style="color: #CE0E2D; margin-bottom: 20px;") Redefinir Senha
      p(style="color: #666; margin-bottom: 25px;") Clique no botão abaixo para criar uma nova senha:
      
      a.button(href=url) Redefinir Minha Senha
    
    p.message(style="font-size: 14px; color: #666; margin-top: 25px;")
      | Se o botão não funcionar, copie e cole este link no seu navegador:<br>
      span(style="color: #CE0E2D; word-break: break-all;") #{url}
    
    .warning
      p 
        strong 🔒 Segurança: 
        | Se você não solicitou esta alteração, por favor ignore este e-mail. Sua senha permanecerá inalterada.

block footer
  .footer
    p.address
      | Anglo - Plataforma Educacional
    
    p.copyright
      | © #{new Date().getFullYear()} Anglo. Todos os direitos reservados.<br>
      | Este é um e-mail de segurança, não compartilhe com ninguém.
