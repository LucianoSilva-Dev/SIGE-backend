# Base Config
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sige_db?schema=public"
HOST=0.0.0.0
PORT=3000
ENVIRONMENT=development
TZ=America/Sao_Paulo
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
DOCS_ENABLED=true

# Authentication (better-auth)
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-chars-long"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false

# Admin Setup
ADMIN_SETUP=true
ADMIN_NAME="Admin Initial"
ADMIN_EMAIL="admin@sige.com"
ADMIN_PASSWORD="AdminPassword123!"
